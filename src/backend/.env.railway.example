# -------------------------------------------------------
# LoanLens Backend — Railway Environment Variables
# -------------------------------------------------------
# Set ALL of these in Railway Dashboard → Variables tab.
# Never commit actual values to git.

GEMINI_API_KEY=your_key_from_aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash-lite

ENVIRONMENT=production

# After Vercel frontend is deployed, replace with your actual Vercel URL.
# Comma-separated if multiple (preview + production):
# CORS_ORIGINS=https://loanlens.vercel.app,https://loanlens-git-main-yourname.vercel.app
CORS_ORIGINS=https://your-frontend.vercel.app

# PORT is automatically injected by Railway — do NOT set this manually.
# PORT=8080
