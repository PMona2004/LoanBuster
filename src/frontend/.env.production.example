# -------------------------------------------------------
# LoanLens Frontend — Vercel Environment Variables
# -------------------------------------------------------
# Set BOTH of these in Vercel Dashboard → Settings → Environment Variables.
# Apply to: Production, Preview, Development.
# Never commit actual values to git.

# Your Railway backend URL (get this after Railway deployment):
VITE_API_URL=https://your-backend.up.railway.app/api/v1

# Slightly above Railway's default request timeout (no hard cap unlike Vercel).
# 310000ms = 310s, matching the original Cloud Run 300s + buffer.
VITE_ANALYZE_TIMEOUT_MS=310000
